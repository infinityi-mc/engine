# Engine server URL (default: /api — uses Vite proxy in dev)
# Set to http://localhost:3000 for direct access or when building for production
# PUBLIC_ENGINE_URL=http://localhost:3000

# Optional: default JWT token for development
# Get one by running: JWT_SECRET=your-secret bun -e "console.log(require('jose').SignJWT({scope:'system:files:read system:files:write system:terminal:execute server:instance:read server:instance:write minecraft:server:read minecraft:server:write agent:run agent:list mcdoc:read'}).setProtectedHeader({alg:'HS256'}).setIssuedAt().setExpirationTime('7d').sign(new TextEncoder().encode(process.env.JWT_SECRET)))"
# PUBLIC_JWT_TOKEN=your-dev-token-here
